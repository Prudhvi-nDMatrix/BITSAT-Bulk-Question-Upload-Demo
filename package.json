    "ioredis": "^5.10.1",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.2",
    "nodemon": "^3.1.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
